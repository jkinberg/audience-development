# Gemini API key (Stage 1 scoring + discovery publication scoring)
GEMINI_API_KEY=

# Anthropic API key (Stage 2 enrichment — Claude Sonnet)
ANTHROPIC_API_KEY=

# Gmail SMTP credentials for email delivery
# Create an App Password at: https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=

# Your personal Substack URL (used for feedback loop — checking your Notes for reshares)
# Example: https://yourname.substack.com
SUBSTACK_URL=

# Your Substack handle (without the .substack.com — used to fetch your subscriptions list)
# Example: yourname
SUBSTACK_HANDLE=

# Email address to deliver the daily digest to. Defaults to GMAIL_ADDRESS if unset.
USER_EMAIL=
