{
  "user": {
    "substack_handle": null,
    "substack_url": null
  },
  "fetch": {
    "lookback_days": 1,
    "first_run_lookback_days": 3,
    "delay_between_pubs_seconds": 0.75,
    "max_posts_per_pub": 10,
    "timeout_seconds": 15
  },
  "scoring": {
    "stage1_model": "gemini-3.1-flash-lite-preview",
    "stage1_temperature": 0,
    "stage2_model": "gemini-3.1-pro-preview",
    "stage2_fallback_model": "claude-sonnet-4-20250514"
  },
  "output": {
    "digest_dir": "output/digests"
  },
  "delivery": {
    "enabled": true,
    "to_email": null,
    "subject_template": "Substack Signal Pipeline — {date} — {high_signal_count} high signal",
    "skip_empty": true
  },
  "feedback": {
    "lookback_days": 7,
    "enabled": true
  },
  "discovery": {
    "recommendation_depth": 2,
    "min_recent_posts": 3,
    "min_publication_score": 5.0
  }
}
